package com.ab3d2.world;

import com.ab3d2.assets.WadTextureData;
import com.ab3d2.assets.WallTextureExtractor;
import com.ab3d2.core.level.*;
import com.jme3.asset.AssetManager;
import com.jme3.material.Material;
import com.jme3.material.RenderState;
import com.jme3.math.ColorRGBA;
import com.jme3.math.Vector3f;
import com.jme3.scene.*;
import com.jme3.texture.Image;
import com.jme3.texture.Texture2D;
import com.jme3.util.BufferUtils;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.io.IOException;
import java.nio.ByteBuffer;
import java.nio.file.*;
import java.util.*;

/**
 * Construit le mesh 3D JME d'un niveau.
 *
 * Système de coordonnées AB3D2 → JME :
 *   jme.x =  world.x  / SCALE
 *   jme.y = -heightOf  / SCALE   (hauteurs inversées : grand = bas dans l'original)
 *   jme.z =  world.z  / SCALE
 *
 * Toutes les materials ont le culling désactivé (FaceCullMode.Off) pour que
 * les faces s'affichent quel que soit le sens de leurs normales.
 */
public class LevelMeshBuilder {

    private static final Logger log = LoggerFactory.getLogger(LevelMeshBuilder.class);

    public static final float SCALE = 32f;

    private final AssetManager      assetManager;
    private final Path               wallsDir;
    private final Map<String, Material> matCache = new LinkedHashMap<>();
    private final List<WadTextureData>  wads     = new ArrayList<>();

    public LevelMeshBuilder(AssetManager assetManager, Path wallsDir) {
        this.assetManager = assetManager;
        this.wallsDir      = wallsDir;
    }

    // ── API ───────────────────────────────────────────────────────────────────

    public Node build(LevelData level) {
        log.info("Building mesh LEVEL_{} — {} zones, {} edges",
                 level.levelId, level.numValidZones(), level.numEdges());
        loadWads();

        Node root = new Node("level_" + level.levelId);
        int builtZones = 0;

        for (int zi = 0; zi < level.numZones(); zi++) {
            ZoneData zone = level.zone(zi);
            if (zone == null) continue;
            if (zone.edgeIds == null || zone.edgeIds.length == 0) continue;

            Node zn = buildZone(level, zone);
            if (zn != null) { root.attachChild(zn); builtZones++; }
        }

        int totalGeo = countGeometries(root);
        log.info("Mesh terminé : {} zones, {} géometries", builtZones, totalGeo);
        return root;
    }

    // ── Zone ──────────────────────────────────────────────────────────────────

    private Node buildZone(LevelData level, ZoneData zone) {
        // Hauteurs — inversées dans l'original (grand = bas)
        float yFloor = -zone.floorHeight() / SCALE;
        float yRoof  = -zone.roofHeight()  / SCALE;

        // Sanity : floor doit être sous le roof en JME (Y up)
        // Si floorHeight > roofHeight → yFloor < yRoof ✓
        // Cas dégénéré : permuter
        if (yFloor > yRoof) { float tmp = yFloor; yFloor = yRoof; yRoof = tmp; }

        // Hauteur minimale de la salle
        if (Math.abs(yRoof - yFloor) < 0.01f) return null;

        float bright = 0.2f + (zone.brightness & 0x3F) / 63f * 0.8f;
        Node zoneNode = new Node("zone_" + (zone.zoneId & 0xFFFF));

        // ── Murs solides ──────────────────────────────────────────────────────
        for (short edgeId : zone.edgeIds) {
            ZEdge edge = level.edge(edgeId & 0xFFFF);
            if (edge == null || edge.isPortal()) continue;
            Geometry g = buildWall(edge, yFloor, yRoof, bright, edgeId & 0xFFFF);
            if (g != null) zoneNode.attachChild(g);
        }

        // ── Sol ───────────────────────────────────────────────────────────────
        Geometry floor = buildHorizontalPoly(level, zone, yFloor, true, bright * 0.55f);
        if (floor != null) zoneNode.attachChild(floor);

        // ── Plafond ───────────────────────────────────────────────────────────
        Geometry ceil = buildHorizontalPoly(level, zone, yRoof, false, bright * 0.35f);
        if (ceil != null) zoneNode.attachChild(ceil);

        return zoneNode.getChildren().isEmpty() ? null : zoneNode;
    }

    // ── Mur ──────────────────────────────────────────────────────────────────

    private Geometry buildWall(ZEdge edge, float yFloor, float yRoof,
                               float bright, int edgeId) {
        float x0 = edge.pos().xi() / SCALE;
        float z0 = edge.pos().zi() / SCALE;
        float x1 = (edge.pos().xi() + edge.len().xi()) / SCALE;
        float z1 = (edge.pos().zi() + edge.len().zi()) / SCALE;

        float wallLen = (float) Math.sqrt((x1-x0)*(x1-x0) + (z1-z0)*(z1-z0));
        if (wallLen < 0.001f) return null;

        float wallH = yRoof - yFloor;
        float uTile = Math.max(1f, wallLen);
        float vTile = Math.max(1f, wallH);

        // 4 sommets — deux triangles, les deux côtés visibles (CullMode.Off)
        Vector3f[] verts = {
            new Vector3f(x0, yFloor, z0),
            new Vector3f(x1, yFloor, z1),
            new Vector3f(x1, yRoof,  z1),
            new Vector3f(x0, yRoof,  z0),
        };
        float[] uvs  = { 0, 0,  uTile, 0,  uTile, vTile,  0, vTile };
        int[]   idx  = { 0, 1, 2,  0, 2, 3 };

        Mesh mesh = new Mesh();
        mesh.setBuffer(VertexBuffer.Type.Position, 3, BufferUtils.createFloatBuffer(verts));
        mesh.setBuffer(VertexBuffer.Type.TexCoord,  2, uvs);
        mesh.setBuffer(VertexBuffer.Type.Index,     3, idx);
        mesh.updateBound();

        Geometry geo = new Geometry("wall_" + edgeId, mesh);
        geo.setMaterial(wallMat(edgeId, bright));
        return geo;
    }

    // ── Sol / plafond ─────────────────────────────────────────────────────────

    private Geometry buildHorizontalPoly(LevelData level, ZoneData zone,
                                          float y, boolean isFloor, float bright) {
        // Sommets depuis les positions de départ de chaque edge (ordre zonaire)
        List<Vector3f> pts = new ArrayList<>();
        for (short eid : zone.edgeIds) {
            ZEdge edge = level.edge(eid & 0xFFFF);
            if (edge == null) continue;
            pts.add(new Vector3f(edge.pos().xi() / SCALE, y, edge.pos().zi() / SCALE));
        }
        if (pts.size() < 3) return null;

        // Triangulation en éventail depuis le centroïde
        int n = pts.size();
        float cx = 0, cz = 0;
        for (Vector3f p : pts) { cx += p.x; cz += p.z; }
        cx /= n; cz /= n;

        Vector3f[] vArr = new Vector3f[n + 1];
        vArr[0] = new Vector3f(cx, y, cz); // centroïde
        for (int i = 0; i < n; i++) vArr[i + 1] = pts.get(i);

        // Indices : pour chaque côté, triangle (centroïde, Pi, Pi+1)
        int[] idx = new int[n * 3];
        for (int i = 0; i < n; i++) {
            int next = (i + 1) % n + 1;
            if (isFloor) {
                idx[i*3    ] = 0;
                idx[i*3 + 1] = i + 1;
                idx[i*3 + 2] = next;
            } else {
                idx[i*3    ] = 0;
                idx[i*3 + 1] = next;
                idx[i*3 + 2] = i + 1;
            }
        }

        // UV planar simple
        float[] uvs = new float[(n + 1) * 2];
        uvs[0] = cx * 0.1f; uvs[1] = cz * 0.1f;
        for (int i = 0; i < n; i++) {
            uvs[(i+1)*2    ] = vArr[i+1].x * 0.1f;
            uvs[(i+1)*2 + 1] = vArr[i+1].z * 0.1f;
        }

        Mesh mesh = new Mesh();
        mesh.setBuffer(VertexBuffer.Type.Position, 3, BufferUtils.createFloatBuffer(vArr));
        mesh.setBuffer(VertexBuffer.Type.TexCoord,  2, uvs);
        mesh.setBuffer(VertexBuffer.Type.Index,     3, idx);
        mesh.updateBound();

        Geometry geo = new Geometry(isFloor ? "floor_" : "ceil_" + (zone.zoneId & 0xFFFF), mesh);
        geo.setMaterial(solidMat(isFloor
            ? new ColorRGBA(bright * 0.4f, bright * 0.45f, bright * 0.5f, 1f)
            : new ColorRGBA(bright * 0.2f, bright * 0.22f, bright * 0.25f, 1f)));
        return geo;
    }

    // ── Matériaux ─────────────────────────────────────────────────────────────

    private Material wallMat(int edgeId, float bright) {
        if (!wads.isEmpty()) {
            WadTextureData wad = wads.get(edgeId % wads.size());
            String key = "wad_" + wad.name() + "_" + (int)(bright * 10);
            return matCache.computeIfAbsent(key, k -> {
                Material m = new Material(assetManager, "Common/MatDefs/Misc/Unshaded.j3md");
                m.setTexture("ColorMap", wad2tex(wad));
                m.setColor("Color", new ColorRGBA(bright, bright, bright, 1f));
                m.getAdditionalRenderState().setFaceCullMode(RenderState.FaceCullMode.Off);
                return m;
            });
        }
        // Couleur unie variant par edge pour visualiser la structure
        float h = (edgeId & 0xFF) / 255f;
        return solidMat(new ColorRGBA(
            bright * (0.3f + h * 0.3f),
            bright * (0.4f),
            bright * (0.5f - h * 0.2f), 1f));
    }

    private Material solidMat(ColorRGBA col) {
        String key = "solid_" + Float.floatToIntBits(col.r)
                               + Float.floatToIntBits(col.g)
                               + Float.floatToIntBits(col.b);
        return matCache.computeIfAbsent(key, k -> {
            Material m = new Material(assetManager, "Common/MatDefs/Misc/Unshaded.j3md");
            m.setColor("Color", col);
            // CullMode Off : visible des deux côtés, peu importe le sens des normales
            m.getAdditionalRenderState().setFaceCullMode(RenderState.FaceCullMode.Off);
            return m;
        });
    }

    // ── WAD → JME Texture ────────────────────────────────────────────────────

    private Texture2D wad2tex(WadTextureData wad) {
        int w = wad.width(), h = wad.height();
        ByteBuffer buf = ByteBuffer.allocateDirect(w * h * 4);
        for (int px : wad.pixels()) {
            buf.put((byte)((px >> 16) & 0xFF));
            buf.put((byte)((px >>  8) & 0xFF));
            buf.put((byte)( px        & 0xFF));
            buf.put((byte)((px >> 24) & 0xFF));
        }
        buf.flip();
        Image img = new Image(Image.Format.RGBA8, w, h, buf,
                              com.jme3.texture.image.ColorSpace.sRGB);
        Texture2D tex = new Texture2D(img);
        tex.setWrap(Texture2D.WrapMode.Repeat);
        tex.setMagFilter(Texture2D.MagFilter.Nearest);
        tex.setMinFilter(Texture2D.MinFilter.NearestNoMipMaps);
        return tex;
    }

    private void loadWads() {
        if (wallsDir == null || !Files.isDirectory(wallsDir)) return;
        int[] pal = new int[256];
        for (int i = 0; i < 256; i++) pal[i] = 0xFF000000 | (i << 16) | (i << 8) | i;
        try {
            new WallTextureExtractor(pal).loadAll(wallsDir).values().forEach(wads::add);
            log.info("{} textures .256wad chargées", wads.size());
        } catch (IOException e) {
            log.warn("Textures mur non chargées : {}", e.getMessage());
        }
    }

    private int countGeometries(Node n) {
        int c = 0;
        for (var ch : n.getChildren()) {
            if (ch instanceof Geometry) c++;
            else if (ch instanceof Node nd) c += countGeometries(nd);
        }
        return c;
    }

    public int getMaterialCount() { return matCache.size(); }
}
